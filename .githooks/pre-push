#!/usr/bin/env bash
# Pre-push hook: run typecheck before pushing
#
# Typecheck catches ~60% of CI failures (schema changes without mock updates).
# Full test suite is left to CI — local environments vary and some tests need
# CI-specific setup (React act shim, embedded Postgres config, etc.).

set -euo pipefail

echo "pre-push: running typecheck..."
pnpm -r typecheck
echo "pre-push: typecheck passed."
